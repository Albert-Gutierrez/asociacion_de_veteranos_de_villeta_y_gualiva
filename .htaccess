# Bloquea el acceso a cualquier ruta con un componente que empiece por punto
# (.env, .git/ y todo su contenido, .htaccess, etc.) sin importar la profundidad.
# Envuelto en <IfModule> para no romper el sitio en hosts sin mod_rewrite.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule "(^|/)\." - [F,L]
</IfModule>

# Respaldo para servidores sin mod_rewrite habilitado (o defensa adicional)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Bloquea el acceso directo a archivos de configuración de Composer
<FilesMatch "^composer\.(json|lock)$">
    Require all denied
</FilesMatch>

Options -Indexes
