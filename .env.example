# Copia este archivo a ".env" y completa los valores reales.
# El archivo ".env" NUNCA debe subirse al repositorio (ya está en .gitignore).

# Base de datos
# En XAMPP local: 127.0.0.1. En hosting compartido (cPanel) suele ser
# "localhost", y el nombre de BD/usuario normalmente vienen prefijados con
# tu usuario de cPanel (ej: "cpaneluser_asovegu"). Ajusta según tu proveedor.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=asovegu
DB_USER=asovegu_app
DB_PASS=

# Correo (SMTP Gmail con contraseña de aplicación)
# Genera la contraseña de aplicación en: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=
SMTP_FROM=tu_correo@gmail.com
SMTP_FROM_NAME="Asociación de Veteranos de Villeta y Gualivá"
DESTINATARIO_ASOCIADOS=asovegu@gmail.com
